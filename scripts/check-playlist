#!/usr/bin/env bash
# Check the configured YouTube playlist for new videos and queue them.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_DIR="$(dirname "$SCRIPT_DIR")"
WORKSPACE_DIR="$(cd "$REPO_DIR/../../.." && pwd)"

if [[ -x "$REPO_DIR/.venv/bin/python" ]]; then
  PYTHON_BIN="$REPO_DIR/.venv/bin/python"
elif [[ -x "$WORKSPACE_DIR/.venv/bin/python" ]]; then
  PYTHON_BIN="$WORKSPACE_DIR/.venv/bin/python"
elif command -v python3 >/dev/null 2>&1; then
  PYTHON_BIN="$(command -v python3)"
else
  echo "No Python interpreter found (.venv/bin/python or python3)." >&2
  exit 1
fi

cd "$REPO_DIR"
PYTHONPATH="$REPO_DIR/src${PYTHONPATH:+:$PYTHONPATH}" exec "$PYTHON_BIN" -m cli "$@"

